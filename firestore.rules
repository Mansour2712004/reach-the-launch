rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDoc().role;
    }

    function isAdmin() {
      return isSignedIn() && (userRole() == 'admin' || userRole() == 'superadmin');
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    // Superadmin always passes. A regular admin only passes if the
    // superadmin has explicitly switched this permission on for them.
    function hasPermission(perm) {
      return isSuperAdmin() ||
        (isSignedIn() && userRole() == 'admin' && userDoc().permissions[perm] == true);
    }

    // Anyone (including guests) can browse launches & developers.
    match /launches/{launchId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('launches');
    }

    match /developers/{devId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('developers');
    }

    // Homepage special offer banner — public read, gated write.
    match /settings/specialOffer {
      allow read: if true;
      allow write: if hasPermission('offers');
    }

    // WhatsApp contact number — public read (the whole point is anyone can
    // see/use it), superadmin-only write (never delegated to sub-admins).
    match /settings/whatsapp {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Users can read/create their own profile; only superadmin can change
    // roles or permissions. Browsing the full user list is superadmin-only.
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if (isSignedIn() && request.auth.uid == uid &&
                          request.resource.data.role == resource.data.role &&
                          request.resource.data.permissions == resource.data.permissions)
                    || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Any signed-in user can submit a contact request, but only admins with
    // the 'submissions' permission can read, mark done, or delete them.
    match /contactSubmissions/{subId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if hasPermission('submissions');
    }
  }
}

<?xml version="1.0" encoding="UTF-8"?>
<!--
  Replace YOUR-DOMAIN-HERE with your real domain once you connect one on
  Vercel. This covers the site's fixed pages. Individual launch and
  developer pages are created dynamically in Firestore, so they can't be
  listed here automatically without a small backend step — see README.md
  ("SEO" section) for how to add that later if you want it.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://YOUR-DOMAIN-HERE/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://YOUR-DOMAIN-HERE/launches</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://YOUR-DOMAIN-HERE/developers</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
</urlset>
